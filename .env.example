# ===============================
# GitAgent Environment Variables
# ===============================

# 🔑 AI Model API Key (Gemini - Free Tier Supported)
GEMINI_API_KEY=your-gemini-api-key

# 🔐 GitHub Access Token (for PR reviews, comments, etc.)
GITHUB_TOKEN=your-github-token

# 📦 Repository (format: owner/repo-name)
GITHUB_REPO=your-username/your-repo-name

# 🔢 Pull Request Metadata (used during testing / CI)
PR_NUMBER=1
PR_TITLE=Sample PR Title
PR_DESCRIPTION=Sample PR Description

# 📄 Optional: Local PR diff file (for testing)
# You can pass this dynamically instead of storing here
# PR_DIFF=path-to-your-pr.diff